{
  "name": "slack-ai-agent-eve",
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#*": "./agent/*",
    "#evals/*": "./evals/*"
  },
  "scripts": {
    "build": "eve build",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- drizzle-kit migrate",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "dev": "eve dev",
    "start": "eve start",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@github-tools/sdk": "^1.8.0",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/connect": "^0.3.2",
    "ai": "^7.0.0",
    "cron-parser": "^5.6.1",
    "drizzle-orm": "^0.45.2",
    "eve": "^0.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "24.x",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "microsandbox": "^0.5.10",
    "typescript": "7.0.1-rc"
  },
  "engines": {
    "node": "24.x"
  }
}
