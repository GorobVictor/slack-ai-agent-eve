# Copy this file to .env.local for local development.
# Keep real values out of git.

# Neon Postgres
# Used by agent/storage/db.ts and Drizzle migrations.
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Upstash Redis
# Used by @upstash/redis Redis.fromEnv() in agent/storage/redis.ts.
UPSTASH_REDIS_REST_URL="https://example.upstash.io"
UPSTASH_REDIS_REST_TOKEN="example-token"

# Vercel Connect / Slack
# Slack credentials are resolved through @vercel/connect using the client UID
# configured in agent/channels/slack.ts:
#   connectSlackCredentials("slack/eve")
# Provision and link that integration through Vercel Connect instead of placing
# Slack bot tokens in this file.
