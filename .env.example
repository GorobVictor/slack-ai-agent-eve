# Copy this file to .env.local for local development.
# Keep real values out of git.

# Neon Postgres
# Used by agent/lib/storage/db.ts, Postgres-backed cache, and Drizzle migrations.
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Vercel Connect / Slack
# Slack credentials are resolved through @vercel/connect using the client UID
# configured in agent/channels/slack.ts:
#   connectSlackCredentials("slack/eve")
# Provision and link that integration through Vercel Connect instead of placing
# Slack bot tokens in this file.
